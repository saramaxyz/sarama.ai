{% set prefix = prefix | default("") %}
{% set ogImage = ogImage | default("https://sarama.ai/brand/logo.svg") %}
{% set canonical = canonical | default(false) %}
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{{ title }}</title>
<meta name="description" content="{{ description }}" />
{% if canonical %}<link rel="canonical" href="{{ canonical }}" />{% endif %}
<meta property="og:type" content="{{ ogType | default('website') }}" />
<meta property="og:site_name" content="Sarama" />
<meta property="og:title" content="{{ title }}" />
<meta property="og:description" content="{{ ogDescription | default(description) }}" />
{% if canonical %}<meta property="og:url" content="{{ canonical }}" />{% endif %}
<meta property="og:image" content="{{ ogImage }}" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="{{ title }}" />
<meta name="twitter:description" content="{{ twitterDescription | default(ogDescription | default(description)) }}" />
<meta name="twitter:image" content="{{ ogImage }}" />
<link rel="icon" href="{{ prefix }}brand/favicon.ico" sizes="any" />
<link rel="icon" type="image/png" sizes="16x16" href="{{ prefix }}brand/favicon-16.png" />
<link rel="icon" type="image/png" sizes="32x32" href="{{ prefix }}brand/favicon.png" />
<link rel="icon" type="image/png" sizes="48x48" href="{{ prefix }}brand/favicon-48.png" />
<link rel="apple-touch-icon" sizes="180x180" href="{{ prefix }}brand/icon-180.png" />
<link rel="apple-touch-icon" sizes="256x256" href="{{ prefix }}brand/apple-touch-icon.png" />
<link rel="manifest" href="{{ prefix }}site.webmanifest" />
<meta name="theme-color" content="#f0eee7" />
<link rel="preload" as="font" type="font/woff2" href="{{ prefix }}brand/fonts/Tid-Light.woff2" crossorigin />
<link rel="preload" as="font" type="font/woff2" href="{{ prefix }}brand/fonts/Inter-Latin.woff2" crossorigin />
<link rel="stylesheet" href="{{ prefix }}assets/base.css" />
{% if pageStyle %}<link rel="stylesheet" href="{{ prefix }}assets/{{ pageStyle }}.css" />{% endif %}
